# MeridianIQ Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# ──────────────────────────────────────────────────────────────
# Required (dev + prod)
# ──────────────────────────────────────────────────────────────

# Supabase connection — used by SupabaseStore and auth/JWKS client.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT shared secret (HS256 path).  Newer Supabase projects use ES256 + JWKS
# and don't need this; keep set for retrocompatibility.
SUPABASE_JWT_SECRET=your-jwt-shared-secret-here

# Environment: "development" uses InMemoryStore, "production" uses SupabaseStore.
# Production also enforces fail-closed auth and strict CORS.
ENVIRONMENT=development

# ──────────────────────────────────────────────────────────────
# Required (prod only)
# ──────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.  Applies only when set;
# a sensible default covering localhost + meridianiq.vitormr.dev is used
# otherwise.  See ADR referenced by audit AUDIT-004.
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4321,https://meridianiq.vitormr.dev,https://your-fork.example

# Sentry DSN — when unset, Sentry is not initialised.
# SENTRY_DSN=https://public@sentry.example.io/project-id

# ──────────────────────────────────────────────────────────────
# Optional features
# ──────────────────────────────────────────────────────────────

# Claude API — used by /analytics/nlp_query.py and the Conversational Builder.
# When unset, the endpoints that depend on it return 501.
# ANTHROPIC_API_KEY=sk-ant-...

# PostHog analytics (frontend) — used by web/src/lib/posthog setup.  Vite
# exposes any PUBLIC_ prefixed var to the browser.
# PUBLIC_POSTHOG_KEY=phc_...

# Uvicorn port override.  Fly.io sets this to 8080 via fly.toml.
# PORT=8080

# ──────────────────────────────────────────────────────────────
# Deploy-only (CI/CD)
# ──────────────────────────────────────────────────────────────

# Fly.io deploy token — consumed by `flyctl deploy` in CI, not by the app.
# FLY_API_TOKEN=fo1_...
